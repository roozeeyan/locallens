# Bybit API (получить на bybit.com → API Management)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Тестовая сеть (true = бумажные деньги, false = реал)
BYBIT_TESTNET=true

# Claude AI (получить на console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Торговые параметры
TOTAL_CAPITAL_USDT=1000
MAX_AGENTS=4
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
